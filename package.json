{
    "name": "aerospace",
    "version": "0.0.1",
    "description": "aerospace engineering problem solver and gas dynamics utilities",
    "homepage": "https://github.com/samrauer/aerospace",
    "author": "Sam Auerbach (samrauer.github.io)",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/samrauer/aerospace.git"
    },
    "type": "module",
    "main": "./lib/index.js",
